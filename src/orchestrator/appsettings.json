{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Kestrel": {
    "Endpoints": {
      "Grpc": {
        "Url": "http://0.0.0.0:5006",
        "Protocols": "Http2"
      }
    }
  },
  "RabbitMq": {
    "Host": "rabbitmq",
    "Port": 5672,
    "Username": "guest",
    "Password": "guest",
    "VirtualHost": "/"
  },
  "Orchestrator": {
    "StatePath": "/tmp/bifrost-orchestrator-state.json",
    "MasterSeed": 0,
    "IterationSeedRotationSeconds": 300,
    "NewsLibraryPath": "/app/config/news-library.json",
    "Heartbeat": {
      "Enabled": false,
      "ToleranceSeconds": 10
    }
  }
}
