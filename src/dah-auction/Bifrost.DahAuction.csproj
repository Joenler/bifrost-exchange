<Project Sdk="Microsoft.NET.Sdk.Web">

    <ItemGroup>
        <!-- Microsoft.Extensions.Hosting and Microsoft.Extensions.Logging.Abstractions are
             supplied transitively by Microsoft.AspNetCore.App (the implicit FrameworkReference
             from Microsoft.NET.Sdk.Web). Adding them as direct PackageReferences trips NU1510
             ("will not be pruned") under TreatWarningsAsErrors. Polly.Core and RabbitMQ.Client
             stay explicit — both are consumed directly from this host. -->
